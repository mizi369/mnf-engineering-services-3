{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Job reservation for engineering services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "serviceType": { "type": "string" },
        "unitType": { "type": "string" },
        "quantity": { "type": "string" },
        "timeSlot": { "type": "string" },
        "team": { "type": "string" },
        "teamId": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Completed"] },
        "location_lat": { "type": "number" },
        "location_lng": { "type": "number" }
      },
      "required": ["date", "customerName", "phone", "serviceType", "status"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Staff and technicians",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icNumber": { "type": "string" },
        "address": { "type": "string" },
        "position": { "type": "string", "enum": ["Manager", "Technician", "Senior Technician", "Admin"] },
        "basic_salary": { "type": "number" },
        "type": { "type": "string", "enum": ["Full-time", "Part-time"] },
        "epf_enabled": { "type": "number" },
        "socso_enabled": { "type": "number" }
      },
      "required": ["name", "icNumber", "position"]
    },
    "Payroll": {
      "title": "Payroll",
      "description": "Salary disbursement records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "month": { "type": "string" },
        "year": { "type": "string" },
        "basic_salary": { "type": "number" },
        "epf_employee": { "type": "number" },
        "epf_employer": { "type": "number" },
        "socso_employee": { "type": "number" },
        "socso_employer": { "type": "number" },
        "advance": { "type": "number" },
        "gross": { "type": "number" },
        "net": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["Tunai", "Transfer"] },
        "status": { "type": "string", "enum": ["Paid", "Pending"] }
      },
      "required": ["employeeId", "month", "year", "net", "status"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Stock items and materials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopName": { "type": "string" },
        "itemName": { "type": "string" },
        "unit": { "type": "string", "enum": ["pcs", "unit", "set", "kg", "batang"] },
        "stock": { "type": "number" },
        "status": { "type": "string", "enum": ["Ada", "Habis"] },
        "buyPrice": { "type": "number" },
        "sellPrice": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["Debit", "Credit"] },
        "paymentMethod": { "type": "string", "enum": ["Tunai", "Transfer"] },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["itemName", "unit", "stock", "status"]
    },
    "SaleRecord": {
      "title": "Sale Record",
      "description": "Direct service sales",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "serviceDescription": { "type": "string" },
        "adminName": { "type": "string" },
        "amount": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["Debit", "Credit"] },
        "paymentMethod": { "type": "string", "enum": ["Tunai", "Transfer"] },
        "status": { "type": "string", "enum": ["Pembayaran Diterima", "Peringatan Bayaran"] }
      },
      "required": ["date", "customerName", "total", "status"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenditures",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Maintenance", "Fuel", "Others"] },
        "paymentType": { "type": "string", "enum": ["Debit", "Credit"] },
        "paymentMethod": { "type": "string", "enum": ["Tunai", "Transfer"] }
      },
      "required": ["date", "amount", "category"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client database",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "lastService": { "type": "string", "format": "date" },
        "totalSpent": { "type": "number" },
        "adMessage": { "type": "string" }
      },
      "required": ["name", "phone"]
    },
    "Setting": {
      "title": "Setting",
      "description": "System configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "key": { "type": "string" },
        "value": { "type": "any" }
      },
      "required": ["key", "value"]
    },
    "AiMapping": {
      "title": "AI Mapping",
      "description": "AI Question to Answer mapping",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "questionId": { "type": "string" },
        "answerId": { "type": "string" },
        "priority": { "type": "string", "enum": ["Tinggi", "Sederhana", "Rendah"] },
        "triggers": { "type": "string" },
        "status": { "type": "string", "enum": ["Aktif", "Nyahaktif"] }
      },
      "required": ["questionId", "answerId", "status"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "WhatsApp communication logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["user", "ai"] },
        "body": { "type": "string" },
        "time": { "type": "string" },
        "phone": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["senderRole", "body", "phone"]
    },
    "AppDocument": {
      "title": "App Document",
      "description": "Invoices and Quotations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["invoice", "quotation"] },
        "refNo": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "customerName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["type", "refNo", "date", "customerName", "total"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "Marketing campaigns and discounts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["message", "status"]
    },
    "AiQuestion": {
      "title": "AI Question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "status": { "type": "string", "enum": ["Aktif", "Nyahaktif"] }
      },
      "required": ["question", "status"]
    },
    "AiAnswer": {
      "title": "AI Answer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "answer": { "type": "string" },
        "status": { "type": "string", "enum": ["Aktif", "Nyahaktif"] }
      },
      "required": ["answer", "status"]
    },
    "AiTraining": {
      "title": "AI Training",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "input": { "type": "string" },
        "status": { "type": "string", "enum": ["Aktif", "Menunggu", "Ditolak"] }
      },
      "required": ["input", "status"]
    },
    "AiLock": {
      "title": "AI Lock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "keyName": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["keyName", "active"]
    },
    "AiLearningLog": {
      "title": "AI Learning Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "activity": { "type": "string" },
        "status": { "type": "string", "enum": ["Sah", "Batal"] }
      },
      "required": ["activity", "status"]
    },
    "ServicePrice": {
      "title": "Service Price",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" }
      },
      "required": ["name", "price"]
    },
    "BlockedSlot": {
      "title": "Blocked Slot",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "timeSlot": { "type": "string" }
      },
      "required": ["date", "timeSlot"]
    },
    "TimeSlotConfig": {
      "title": "Time Slot Config",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["label", "active"]
    },
    "TeamConfig": {
      "title": "Team Config",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "active"]
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["debit", "credit"] }
      },
      "required": ["amount", "type"]
    },
    "Template": {
      "title": "Template",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "mnf_bookings": { "schema": "Booking", "description": "Client bookings" },
    "mnf_employees": { "schema": "Employee", "description": "Staff list" },
    "mnf_payroll": { "schema": "Payroll", "description": "Payment records" },
    "mnf_inventory": { "schema": "InventoryItem", "description": "Stock inventory" },
    "mnf_sales": { "schema": "SaleRecord", "description": "Sales logs" },
    "mnf_expenses": { "schema": "Expense", "description": "Expenses logs" },
    "mnf_customers": { "schema": "Customer", "description": "CRM data" },
    "mnf_settings": { "schema": "Setting", "description": "App settings" },
    "mnf_ai_mappings": { "schema": "AiMapping", "description": "AI configuration" },
    "mnf_chat_logs": { "schema": "ChatMessage", "description": "Communication history" },
    "mnf_documents": { "schema": "AppDocument", "description": "Financial documents" },
    "mnf_promotions": { "schema": "Promotion", "description": "Promotions" },
    "mnf_ai_questions": { "schema": "AiQuestion", "description": "AI Questions" },
    "mnf_ai_answers": { "schema": "AiAnswer", "description": "AI Answers" },
    "mnf_ai_training": { "schema": "AiTraining", "description": "AI Training" },
    "mnf_ai_locks": { "schema": "AiLock", "description": "AI Locks" },
    "mnf_ai_learning_logs": { "schema": "AiLearningLog", "description": "AI Learning Logs" },
    "mnf_services": { "schema": "ServicePrice", "description": "Service Prices" },
    "mnf_blocked_slots": { "schema": "BlockedSlot", "description": "Blocked Slots" },
    "mnf_time_slots": { "schema": "TimeSlotConfig", "description": "Time Slots" },
    "mnf_teams": { "schema": "TeamConfig", "description": "Team configurations" },
    "mnf_templates": { "schema": "Template", "description": "Message templates" },
    "mnf_transactions": { "schema": "Transaction", "description": "Financial transactions" }
  }
}
